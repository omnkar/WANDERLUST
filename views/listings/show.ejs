
<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2 mt-3 show-card">
        <h1>Listing Details</h1>
    </div>
    <div class="card col-6 offset-2">
        <img src="<%= listing.image %>" class="card-img-top show-img" alt="Listing_image">
        <div class="card-body">
            <p class="card-text">
                <b><%= listing.title %></b> <br>
                <%= listing.description %><br>
                &#8377; <%= listing.price.toLocaleString("en-IN") %><br>
                <%= listing.location %><br>
                <%= listing.country %><br>

            </p>
        </div>
    </div>
</div>
<div class="btns">
    <br><a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn col-1 offset-2">Edit</a>
    <form action="/listings/<%= listing._id %>/delete?_method=delete" method="post" >
        <button class="btn btn-dark  del-btn offset-4">Delete</button>
    </form>
</div>

    

